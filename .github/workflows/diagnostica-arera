name: Diagnostica download ARERA

on:
  workflow_dispatch:
    inputs:
      data:
        description: "Data da testare in formato YYYY-MM-DD (vuoto = oggi UTC)"
        required: false
        type: string

permissions:
  contents: read

jobs:
  diagnostica-arera:
    runs-on: ubuntu-latest

    steps:
      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Test separato pagina, E, G e D
        env:
          TEST_DATE: ${{ inputs.data }}
        run: |
          python - <<'PY'
          from __future__ import annotations

          import html
          import http.cookiejar
          import os
          import re
          import ssl
          import urllib.error
          import urllib.request
          from datetime import datetime, timezone
          from urllib.parse import urljoin

          OPEN_DATA_URL = "https://www.ilportaleofferte.it/portaleOfferte/it/open-data.page"
          HEADERS = {
              "User-Agent": (
                  "Mozilla/5.0 (Windows NT 10.0; Win64; x64) "
                  "AppleWebKit/537.36 (KHTML, like Gecko) "
                  "Chrome/126.0.0.0 Safari/537.36"
              ),
              "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
              "Accept-Language": "it-IT,it;q=0.9,en;q=0.8",
              "Cache-Control": "no-cache",
          }

          raw_date = (os.environ.get("TEST_DATE") or "").strip()
          if raw_date:
              requested = datetime.strptime(raw_date, "%Y-%m-%d")
          else:
              requested = datetime.now(timezone.utc)

          stamp = requested.strftime("%Y%m%d")
          folder = f"{requested.year}_{requested.month}"
          base = f"https://www.ilportaleofferte.it/portaleOfferte/resources/opendata/csv/offerteML/{folder}"

          direct_links = {
              "E": f"{base}/PO_Offerte_E_MLIBERO_{stamp}.xml",
              "G": f"{base}/PO_Offerte_G_MLIBERO_{stamp}.xml",
              "D": f"{base}/PO_Offerte_D_MLIBERO_{stamp}.xml",
          }

          ssl_context = ssl.create_default_context()
          cookie_jar = http.cookiejar.CookieJar()
          opener = urllib.request.build_opener(
              urllib.request.HTTPCookieProcessor(cookie_jar),
              urllib.request.HTTPSHandler(context=ssl_context),
          )

          summary = []

          def test_url(label: str, url: str, referer: str | None = None) -> tuple[bool, bytes, str]:
              headers = dict(HEADERS)
              if referer:
                  headers["Referer"] = referer
              request = urllib.request.Request(url, headers=headers, method="GET")

              print(f"\n===== {label} =====")
              print(f"URL richiesto: {url}")
              try:
                  with opener.open(request, timeout=60) as response:
                      body = response.read(512)
                      status = getattr(response, "status", response.getcode())
                      final_url = response.geturl()
                      content_type = response.headers.get("Content-Type", "")
                      content_length = response.headers.get("Content-Length", "")
                      print(f"HTTP: {status}")
                      print(f"URL finale: {final_url}")
                      print(f"Content-Type: {content_type}")
                      print(f"Content-Length header: {content_length or 'non presente'}")
                      print(f"Primi byte letti: {len(body)}")
                      print(f"Firma contenuto: {body[:80]!r}")
                      summary.append((label, str(status), content_type, final_url))
                      return True, body, final_url
              except urllib.error.HTTPError as error:
                  response_body = error.read(512)
                  print(f"HTTP: {error.code} {error.reason}")
                  print(f"URL finale: {error.geturl()}")
                  print(f"Content-Type: {error.headers.get('Content-Type', '')}")
                  print(f"Firma risposta errore: {response_body[:120]!r}")
                  summary.append((label, f"{error.code} {error.reason}", error.headers.get("Content-Type", ""), error.geturl()))
                  return False, response_body, error.geturl()
              except Exception as error:
                  print(f"ERRORE: {type(error).__name__}: {error}")
                  summary.append((label, f"ERRORE {type(error).__name__}", "", url))
                  return False, b"", url

          print(f"Data testata: {requested.strftime('%Y-%m-%d')} ({stamp})")
          print("Questo workflow non genera JSON, non modifica file e non esegue commit.")

          page_ok, page_body, page_final_url = test_url("PAGINA OPEN DATA", OPEN_DATA_URL)

          page_links = {}
          if page_ok:
              page_text = page_body.decode("utf-8", errors="replace")
              # La prima lettura è limitata a 512 byte. Rileggiamo la pagina completa solo se accessibile.
              request = urllib.request.Request(OPEN_DATA_URL, headers=HEADERS, method="GET")
              try:
                  with opener.open(request, timeout=60) as response:
                      page_text = response.read().decode("utf-8", errors="replace")
              except Exception as error:
                  print(f"Impossibile rileggere la pagina completa: {error}")

              pattern = re.compile(r'href=["\']([^"\']*PO_Offerte_([EGD])_MLIBERO_\d+\.xml)["\']', re.I)
              for href, kind in pattern.findall(page_text):
                  page_links[kind.upper()] = urljoin(OPEN_DATA_URL, html.unescape(href))

              print("\nLink XML trovati nella pagina:")
              for kind in ("E", "G", "D"):
                  print(f"{kind}: {page_links.get(kind, 'NON TROVATO')}")

          for kind, label in (("E", "XML ELETTRICO"), ("G", "XML GAS"), ("D", "XML DUAL FUEL")):
              url = page_links.get(kind) or direct_links[kind]
              origin = "pagina Open Data" if kind in page_links else f"link diretto data {stamp}"
              print(f"\nOrigine URL {kind}: {origin}")
              test_url(label, url, referer=page_final_url if page_ok else OPEN_DATA_URL)

          print("\n===== RIEPILOGO =====")
          for label, status, content_type, final_url in summary:
              print(f"{label}: {status} | {content_type or 'content-type assente'} | {final_url}")

          github_summary = os.environ.get("GITHUB_STEP_SUMMARY")
          if github_summary:
              with open(github_summary, "a", encoding="utf-8") as out:
                  out.write("# Diagnostica download ARERA\n\n")
                  out.write(f"Data testata: **{requested.strftime('%Y-%m-%d')}**\n\n")
                  out.write("| Risorsa | Esito | Content-Type |\n")
                  out.write("|---|---:|---|\n")
                  for label, status, content_type, _ in summary:
                      out.write(f"| {label} | {status} | {content_type or '-'} |\n")
                  out.write("\nNessun file del repository è stato modificato.\n")
          PY
